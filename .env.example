# Example environment variables for local development (DO NOT commit real keys)
# Copy this file to .env and fill real values before running docker compose or running services.

# Football-data.org token (used by league-service, team-service, match-service)
FOOTBALL_DATA_API_TOKEN=YOUR_FOOTBALL_DATA_API_TOKEN_HERE

# API-Football API key (used by stadium-service)
API_FOOTBALL_API_KEY=YOUR_API_FOOTBALL_API_KEY_HERE

# Optional: Postgres credentials used by docker-compose (defaults are in docker-compose.yml)
#MATCH_DB_PASSWORD=password
#LEAGUE_DB_PASSWORD=password
#TEAM_DB_PASSWORD=password
#STADIUM_DB_PASSWORD=password

